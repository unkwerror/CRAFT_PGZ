# ---------------------------------------------------------------------------
# Конфигурация модуля получения данных (Фаза 0, v1: Excel-выгрузка Контура).
# НИКОГДА не коммить реальный .env. У источника v1 секретов нет — файл выгрузки
# кладёт пользователь вручную. Доступы появятся с EmailSource/DamiaSource.
# ---------------------------------------------------------------------------

# psycopg v3 -> драйвер postgresql+psycopg.
# Для docker compose host = postgres; для локального запуска -> localhost.
DATABASE_URL=postgresql+psycopg://tender:tender@postgres:5432/tender

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# LLM-арбитр релевантности (Фаза 1). По умолчанию mock — без ключа и сети.
# Переключение на YandexGPT: ARBITER_PROVIDER=yandex + ключ и folder_id.
# ---------------------------------------------------------------------------
ARBITER_PROVIDER=mock
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
